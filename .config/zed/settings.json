{
  "agent_buffer_font_size": 24.0,
  "agent_ui_font_size": 20.0,
  "buffer_font_family": "Monaspace Krypton",
  "icon_theme": "Colored Zed Icons Theme Dark",
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "disable_ai": false,
  "agent": {
    "dock": "right",
  },
  "base_keymap": "VSCode",
  "buffer_font_size": 22,
  "format_on_save": "off",
  "indent_guides": {
    "enabled": false
  },
  "project_panel": {
    "dock": "left",
    "auto_fold_dirs": false,
    "indent_guides": {
      "show": "never"
    },
    "indent_size": 20
  },
  "scrollbar": {
    "axes": {
      "horizontal": false,
      "vertical": false
    }
  },
  "terminal": {
    "cursor_shape": "underline",
    "font_family": "Monaspace Krypton",
    "font_size": 20,
    "line_height": "standard"
  },
  "theme": {
    "mode": "system",
    "light": "Rosé Pine Dawn",
    "dark": "Rosé Pine Moon"
  },
  "ui_font_family": "Monaspace Argon",
  "ui_font_size": 20.0,
  "vim": {
    "toggle_relative_line_numbers": true,
    "use_system_clipboard": "always"
  },
  "vim_mode": true
}
